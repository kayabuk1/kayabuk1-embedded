    }
  } else if (search_phase ==
             2) { // フェーズ2：見つからなければ右に大きく探す（100歩）
    turning_right();
    if (search_step >= 100) {
      search_step = 0;
      search_phase = 3; // 次のフェーズへ
    }
  } else if (search_phase == 3) { // フェーズ3：左に戻して中央へ（50歩）
    turning_left();
    if (search_step >= 50) {
      search_step = 0;
