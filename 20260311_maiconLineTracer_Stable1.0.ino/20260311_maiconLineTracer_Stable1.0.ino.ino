  // ★修正：白紙上での不確実なセンサー比較（val_L > val_R）をやめ、
  // コースアウト前に記憶した履歴フラグ（turnDirectionSW）を使う！
  if (turnDirectionSW == 1) {
    // 最後にラインが左側にあったと記憶している → 左から探す
    search_phase = 1; // 左スタート (1,2,3...はturning_left始まりに変更)
  } else {
