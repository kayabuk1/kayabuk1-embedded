// 右へ修正する関数（左輪を速く、右輪を遅く）
// ※右センサーが黒白境界
// map(変換したい値, 元の最小値, 元の最大値, 変換後の最小値,
// 変換後の最大値)を使用する mapping＝対応付ける、割り当てるが元。
void gradually_right() {
  // 【理想状態】黒いラインをy軸とすると車体角度は90度が理想。
  //   白紙
  //          [R]
  //           |
  //   ________|________
  //   黒線    [C]←車体角度90度
  //   ________|________
  //           |
  //          [L]
  //   白紙

  //   白紙
  //   _____[R]___________
  //   黒線   \
  //   ________\__________
  //            [C]↙車体角度例100度
  //              \
  //               \ 
//               [L]
  //   白紙
  //   ⇒この時、黒と白の境界に来るのは右センサーだから右センサーを基準にするのが
  // 正しいと考えた。そしてこれを修正するには車体角度を90度未満、具体例としては80度等
  // にしなければいけない、その動作をする為には、緩やかに右に曲げて行くことが必要。
  // なのでgradually_right();はこの左車輪を速く、右車輪を遅くにする動作で良いのと
  // 結論付け、このコードを記述した。Rセンサーの値が大きくなる＝黒線上に来るほど
  // 左車輪のスピードを上げて、右車輪は反比例させる今のコードで正しいと考えてしまう
  // のだけれど、君の意見は如何だろうか？

  digitalWrite(RA_PHASE, 1);
  digitalWrite(LB_PHASE, 0); // モータの極性が逆になっているため数値を反転
  int r_val = analogRead(R_SENSOR);
  // ★修正1：センサーの入力値を WHITE(下限) ～ BLACK(上限) の範囲に制限する
  // constrain()（コンストレイン）関数：計算結果に「リミッター（上限・下限）」をかける
  // 役割:
  // 変数の値が、指定した**「下限」から「上限」の範囲内に収まるように強制的に丸め込む（制限する）**関数です
  // 使い方: 値 = constrain(元の値, 下限, 上限);
  r_val = constrain(r_val, WHITE, BLACK);
  int speed_up = map(r_val, WHITE, BLACK, HALF_SPEED, MAX_SPEED);
  int speed_down = map(
      r_val, WHITE, BLACK, HALF_SPEED,
      MIN_SPEED); // 反比例させる。
                  //  ★修正2：モーターの出力値を制限し、逆転やストール（エンスト）を防ぐ
  speed_up = constrain(speed_up, HALF_SPEED, MAX_SPEED);
  speed_down = constrain(speed_down, MIN_SPEED, HALF_SPEED);
  analogWrite(RA_ENABLE, speed_down);
  analogWrite(LB_ENABLE, speed_up);
}
// 左へ修正する関数（左輪を遅く、右輪を速く）
// ※左センサーが黒白境界。黒白境界時シリアル値450を想定
void gradually_left() {
  digitalWrite(RA_PHASE, 1);
  digitalWrite(LB_PHASE, 0); // モータの極性が逆になっているため数値を反転
  int l_val = analogRead(L_SENSOR);
  // ★修正1：センサーの入力値を WHITE(下限) ～ BLACK(上限) の範囲に制限する
  l_val = constrain(l_val, WHITE, BLACK);
  int speed_up = map(l_val, WHITE, BLACK, HALF_SPEED, MAX_SPEED);
  // 白：HALF_SPEED(86) ～ 黒：MAX_SPEED(120)
  int speed_down = map(l_val, WHITE, BLACK, HALF_SPEED, MIN_SPEED);
  // 白：HALF_SPEED(86) ～ 黒：MIN_SPEED(51) //反比例させる。
  // ★修正2：モーターの出力値を制限し、逆転やストール（エンスト）を防ぐ
  speed_up = constrain(speed_up, HALF_SPEED, MAX_SPEED);
  speed_down = constrain(speed_down, MIN_SPEED, HALF_SPEED);
  analogWrite(RA_ENABLE, speed_up);
  analogWrite(LB_ENABLE, speed_down);
}
// --- クランク非同期処理 ---

// 左クランク開始（少し前進して、旋回モードに切り替える）
void turn_left90_start() {
  motor_forward();
  delay(220); // ★修正：エラー40対策 - 200では少し浅いため、220へ延長
  turning_left();
  turn_phase = 0;                         // ★追加：抜け確認フラグを初期化
  currentState = STATE_TURN_LEFT90_DOING; // 状態を「旋回中」に移行！
}

// 左クランク旋回中（whileを使わず、メインループの中で黒線を待つ）
void turn_left90_doing() {
  if (turn_phase == 0) {
    // 完全に白(WHITE)を通り越すのをまず検知する（前進150msで完全に外れ切ってない場合があるため）
    if (val_L < GRAY && val_C < GRAY) {
      turn_phase = 1; // ラインから完全に外れた
    }
  } else {
    // 浅い旋回（左センサー）だけでは止めず、中央センサーが黒線を捉えるまで回りきる（エラー33対策）
    if (val_C > LINE_DETECT || val_R > LINE_DETECT) {
      stop_motor();
      // ★エラー40対策：ALIGN段階での「前進しながら片輪を止めるスイングターン」がコースアウトの誘発原因になっていた。
      // P制御が十分強いので、旋回直後はALIGNを挟まず、一気にFORWARDに落としてP制御に滑らかに任せる。
      currentState = STATE_FORWARD;
    }
  }
}

// 右クランク開始
void turn_right90_start() {
  motor_forward();
  delay(220); // ★修正：エラー40対策 - 同上
  turning_right();
  turn_phase = 0; // ★追加：抜け確認フラグを初期化
  currentState = STATE_TURN_RIGHT90_DOING;
}

// 右クランク旋回中
void turn_right90_doing() {
  if (turn_phase == 0) {
    if (val_R < GRAY && val_C < GRAY) {
      turn_phase = 1;
    }
  } else {
    // 浅い旋回（右センサー）だけでは止めず、中央センサーが黒線を捉えるまで回りきる（エラー33対策）
    if (val_C > LINE_DETECT || val_L > LINE_DETECT) {
      stop_motor();
      currentState =
          STATE_FORWARD; // エラー40対策：ALIGNを挟まず、P制御の復元力に任せる
    }
  }
}
// 向き揃え状態：左右センサーの差が小さくなるまでゆっくり修正する
void align_to_line() {
  int diff = val_L - val_R;
  // ★脱出条件：中央が黒であり、かつ左右の差分が小さく、左右共に白（車体がラインと平行）であること
  if (val_C >= LINE_DETECT && abs(diff) < 100 && val_L < GRAY && val_R < GRAY) {
    stop_motor();
    currentState = STATE_FORWARD; // 向きが完全に揃ったので、直進再開！
    return;
  }
  // 万が一、アライメント中に中央が白に落ちてしまった場合は再探索へ
  if (val_C < LINE_LOST) {
    stop_motor();
    currentState = STATE_COMEBACK_START;
    return;
  }

  if (diff > 50) {
    // 左側の値が大きい＝ラインが左寄り＝車体が右を向いている → 左に回す
    // ★エラー38対策：前回のスイングターン修正でRAとLBを勘違いし、逆に曲がって自滅していたバグを修正！
    // 正：右輪(RA)を前進、左輪(LB)を停止にし、確実に左へスイングターン！
    digitalWrite(RA_PHASE, 1);
    digitalWrite(LB_PHASE, 0);         // 前進極性
    analogWrite(RA_ENABLE, MIN_SPEED); // 右(RA)前進
    analogWrite(LB_ENABLE, 0);         // 左(LB)停止
  } else if (diff < -50) {
    // 右側の値が大きい＝ラインが右寄り＝車体が左を向いている → 右に回す
    // ★エラー38対策：同じく勘違いバグを修正。左輪(LB)を前進、右輪(RA)を停止にし、確実に右へスイングターン！
    digitalWrite(RA_PHASE, 1);
    digitalWrite(LB_PHASE, 0);         // 前進極性
    analogWrite(RA_ENABLE, 0);         // 右(RA)停止
    analogWrite(LB_ENABLE, MIN_SPEED); // 左(LB)前進
  } else {
    // 差が小さい場合は微調整完了待ち
    stop_motor();
  }
}
